+func TestProcessDirectWithChannel_PublishesOutboundForRemoteChannel(t *testing.T) {
+	tmpDir := t.TempDir()
+
+	cfg := &config.Config{
+		Agents: config.AgentsConfig{
+			Defaults: config.AgentDefaults{
+				Workspace:         tmpDir,
+				ModelName:         "test-model",
+				MaxTokens:         4096,
+				MaxToolIterations: 3,
+			},
+		},
+	}
+
+	msgBus := bus.NewMessageBus()
+	provider := &simpleMockProvider{response: "cron answer"}
+	al := NewAgentLoop(cfg, msgBus, provider)
+
+	response, err := al.ProcessDirectWithChannel(
+		context.Background(),
+		"hello",
+		"cron-session",
+		"telegram",
+		"chat-1",
+	)
+	if err != nil {
+		t.Fatalf("ProcessDirectWithChannel failed: %v", err)
+	}
+	if response != "cron answer" {
+		t.Fatalf("response = %q, want %q", response, "cron answer")
+	}
+
+	select {
+	case outbound := <-msgBus.OutboundChan():
+		if outbound.Channel != "telegram" {
+			t.Fatalf("outbound channel = %q, want %q", outbound.Channel, "telegram")
+		}
+		if outbound.ChatID != "chat-1" {
+			t.Fatalf("outbound chatID = %q, want %q", outbound.ChatID, "chat-1")
+		}
+		if outbound.Content != "cron answer" {
+			t.Fatalf("outbound content = %q, want %q", outbound.Content, "cron answer")
+		}
+	case <-time.After(2 * time.Second):
+		t.Fatal("expected direct processing to publish an outbound message")
+	}
+}
