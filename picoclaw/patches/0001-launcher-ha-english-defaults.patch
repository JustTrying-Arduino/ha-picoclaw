index 0000000..a1b2c3d
--- /dev/null
+++ b/web/frontend/src/lib/runtime.ts
@@ -0,0 +1,29 @@
+declare global {
+  interface Window {
+    __PICOCLAW_BASE_PATH__?: string
+  }
+}
+
+function getBasePath(): string {
+  if (typeof window !== "undefined" && window.__PICOCLAW_BASE_PATH__) {
+    return window.__PICOCLAW_BASE_PATH__
+  }
+  return ""
+}
+
+export function withBasePath(path: string): string {
+  const base = getBasePath()
+  if (!base) return path
+  if (path.startsWith(base)) return path
+  return base + path
+}
