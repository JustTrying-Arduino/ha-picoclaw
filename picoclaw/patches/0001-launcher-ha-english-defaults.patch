+func serveInjectedIndex(w http.ResponseWriter, r *http.Request, subFS fs.FS) {
+	indexHTML, err := fs.ReadFile(subFS, "index.html")
+	if err != nil {
+		http.Error(w, "index.html missing", http.StatusInternalServerError)
+		return
+	}
+
+	basePath := requestIngressBasePath(r)
+	baseHref := "/"
+	if basePath != "" {
+		baseHref = basePath + "/"
+	}
+
+	basePathJSON, err := json.Marshal(basePath)
+	if err != nil {
+		http.Error(w, "failed to encode runtime config", http.StatusInternalServerError)
+		return
+	}
+
+	injection := fmt.Sprintf(
+		`<base href="%s"><script>window.__PICOCLAW_BASE_PATH__=%s;</script>`,
+		template.HTMLEscapeString(baseHref),
+		string(basePathJSON),
+	)
+
+	body := bytes.Replace(indexHTML, []byte("<head>"), []byte("<head>"+injection), 1)
+	w.Header().Set("Content-Type", "text/html; charset=utf-8")
+	w.WriteHeader(http.StatusOK)
+	_, _ = w.Write(body)
+}
