+func (cb *ContextBuilder) ExportInjectedTools(toolDefs []providers.ToolDefinition) error {
+	data, err := json.MarshalIndent(toolDefs, "", "  ")
+	if err != nil {
+		return err
+	}
+
+	data = append(data, '\n')
+	rendered := string(data)
+
+	cb.injectedToolsMutex.Lock()
+	defer cb.injectedToolsMutex.Unlock()
+
+	if cb.injectedToolsJSON == rendered {
+		return nil
+	}
+
+	if err := os.WriteFile(filepath.Join(cb.workspace, "TOOLS.injected.json"), data, 0o644); err != nil {
+		return err
+	}
+
+	cb.injectedToolsJSON = rendered
+	return nil
+}
